{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:reset": "prisma db push --force-reset --skip-generate --schema=prisma/schema.prisma && npm run prisma:generate && npm run seed",
    "db:reset:initial": "prisma db push --force-reset --skip-generate --schema=prisma/schema.prisma && npm run prisma:generate && npm run seed",
    "seed": "tsx prisma/seed.ts",
    "test": "node --test --import tsx src/*.test.ts",
    "lint": "echo 'No backend lint configured'"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "form-data": "^4.0.6",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "prisma": "^6.19.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
