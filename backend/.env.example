PORT=4000

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# Pinata IPFS — https://pinata.cloud
PINATA_API_KEY=your_key_here
PINATA_API_SECRET=your_secret_here
PINATA_JWT=your_jwt_here
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# PostgreSQL via Neon — https://neon.tech
DATABASE_URL="postgresql://user:pass@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL_DIRECT="postgresql://user:pass@host.region.aws.neon.tech/dbname?sslmode=require"
